{
  "expo": {
    "name": "Stash",
    "slug": "Stash",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "scheme": "stash",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#042F2E",
        "foregroundImage": "./assets/app-icon.png",
        "monochromeImage": "./assets/app-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.stash"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/splash-logo-light.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#042F2E",
          "showLabel": false
        }
      ],
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ef97e1c9-f48e-4c29-9f9a-1d06ba0009e9"
      }
    },
    "owner": "suavis_dev"
  }
}
